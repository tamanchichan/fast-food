@model List<Item>

<div>
    <h1>Fast Food Menu</h1>
    <div>
        <table>
            @foreach(Item item in Model)
            {
                @if(item.Code == "1")
                {
                    <tr><th>Appetizers</th></tr>
                }
                @if(item.Code == "8")
                {
                    <tr><th>Mixed Greens</th></tr>
                }
                <tr>
                    <td>@item.Code.</td>
                    <td>@item.Name</td>
                    @* <td>@item.Description</td> *@
                    <td>$@item.Price</td>
                </tr>
            }
        </table>
    </div>
</div>