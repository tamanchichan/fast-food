@model Cart

<div>
    <h2>Cart</h2>
    <div>
        <button onclick="location.href='@Url.Action("ClearCart", "Home")'">Clear</button>
    </div>
    <div>
        <table>
            @foreach (CartItem cartItem in Model.CartItems)
            {
                <tr>
                    <td>@cartItem.Item.Name</td>
                    <td>@cartItem.Quantity</td>
                </tr>
            }
        </table>
    </div>
</div>